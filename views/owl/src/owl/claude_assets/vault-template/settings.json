{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "owl vault hooks — installed by `owl init --hooks`. All hooks delegate to the `owl hook <name>` dispatcher; no logic lives here.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "owl hook session_start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "owl hook user_prompt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "owl hook post_tool_use"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "owl hook pre_compact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "owl hook stop"
          }
        ]
      }
    ]
  }
}
