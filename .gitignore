# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
build/
dist/
.venv/
venv/

# OS noise
.DS_Store
Thumbs.db

# OMC runtime state — all ignored (rebuilds per session).
# Historical note: project-memory.json was tracked in early commits and
# contained local paths (projectRoot, hotPaths). It was removed from
# tracking in phase P (security remediation). Commit history still has
# the old content — use git-filter-repo if full history scrub is needed.
.omc/

# Defensive: vault data MUST NEVER be committed in the project repo.
# The vault lives at ~/owl-vault (or $OWL_VAULT) as its own data layer.
# If any of these paths appear at the project repo root, they are almost
# certainly misplaced vault content.
/raw/
/compiled/
/outputs/
/inbox/
/research/

# Editor noise
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local state
.claude/

# Local environment
.env
.env.local
